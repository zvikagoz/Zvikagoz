<body>

<div class="container">

<h1>מחשבון מיחזור משכנתא</h1>

<h3>משכנתא קיימת</h3>
<input id="balance" placeholder="יתרה (₪)">
<input id="rateOld" placeholder="ריבית (%)">
<input id="yearsOld" placeholder="שנים שנותרו">

<h3>משכנתא חדשה</h3>
<input id="rateNew" placeholder="ריבית חדשה (%)">
<input id="yearsNew" placeholder="שנים">

<h3>עלויות מיחזור</h3>
<input id="cost" placeholder="עלות מיחזור">

<button onclick="calc()">חשב חיסכון</button>

<div class="result" id="result"></div>

<canvas id="chart"></canvas>

<h3>העלאת דוח יתרות</h3>
<input type="file" id="pdfUpload" accept="application/pdf">

<div id="pdfText"></div>

</div>

<script>

function payment(p,r,n){
let monthly=r/100/12
let months=n*12
return p*monthly/(1-Math.pow(1+monthly,-months))
}

function calc(){

let balance=parseFloat(balance.value)
let rateOld=parseFloat(rateOld.value)
let yearsOld=parseFloat(yearsOld.value)

let rateNew=parseFloat(rateNew.value)
let yearsNew=parseFloat(yearsNew.value)

let cost=parseFloat(cost.value)

let oldPay=payment(balance,rateOld,yearsOld)
let newPay=payment(balance,rateNew,yearsNew)

let saveMonth=oldPay-newPay
let saveTotal=saveMonth*yearsNew*12-cost

result.innerHTML=
`החזר קיים: ₪${oldPay.toFixed(0)}<br>
החזר חדש: ₪${newPay.toFixed(0)}<br>
חיסכון חודשי: ₪${saveMonth.toFixed(0)}<br>
חיסכון כולל: ₪${saveTotal.toFixed(0)}`

drawChart(oldPay,newPay,yearsNew)

}

function drawChart(oldPay,newPay,years){

let months=years*12
let labels=[]
let oldData=[]
let newData=[]

for(let i=0;i<months;i++){
labels.push(i+1)
oldData.push(oldPay)
newData.push(newPay)
}

new Chart(chart,{
type:'line',
data:{
labels:labels,
datasets:[
{label:'תשלום קיים',data:oldData},
{label:'תשלום חדש',data:newData}
]
}
})

}

pdfUpload.addEventListener("change",async function(){

let file=this.files[0]

let reader=new FileReader()

reader.onload=async function(){

let typedarray=new Uint8Array(this.result)

let pdf=await pdfjsLib.getDocument(typedarray).promise

let text=""

for(let i=1;i<=pdf.numPages;i++){

let page=await pdf.getPage(i)
let content=await page.getTextContent()

let strings=content.items.map(x=>x.str)

text+=strings.join(" ")+" "

}

pdfText.innerText=text

let numbers=text.match(/\d+[\.,]?\d*/g)

if(numbers){

let balanceGuess=numbers.find(n=>parseInt(n)>50000)
let rateGuess=numbers.find(n=>parseFloat(n)>1 && parseFloat(n)<10)

if(balanceGuess) balance.value=balanceGuess.replace(/,/g,'')
if(rateGuess) rateOld.value=rateGuess

}

}

reader.readAsArrayBuffer(file)

})

</script>

